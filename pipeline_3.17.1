function Get-CountryName-Unstable {
    param([string]$line)
    if($line -match '\|(🇦🇹|🇧🇪|🇨🇿|🇩🇪|🇩🇰|🇪🇸|🇪🇪|🇫🇮|🇫🇷|🇬🇷|🇭🇷|🇭🇺|🇮🇪|🇮🇸|🇮🇹|🇱🇻|🇱🇹|🇱🇺|🇳🇱|🇳🇴|🇵🇱|🇵🇹|🇷🇴|🇷🇸|🇸🇪|🇸🇮|🇸🇰)\|'){
        switch($Matches[1]){
            "🇦🇹"{"Austria"};"🇧🇪"{"Belgium"};"🇨🇿"{"Czechia"};"🇩🇪"{"Germany"};"🇩🇰"{"Denmark"};"🇪🇸"{"Spain"};"🇪🇪"{"Estonia"};"🇫🇮"{"Finland"};"🇫🇷"{"France"};"🇬🇷"{"Greece"};"🇭🇷"{"Croatia"};"🇭🇺"{"Hungary"};"🇮🇪"{"Ireland"};"🇮🇸"{"Iceland"};"🇮🇹"{"Italy"};"🇱🇻"{"Latvia"};"🇱🇹"{"Lithuania"};"🇱🇺"{"Luxembourg"};"🇳🇱"{"Netherlands"};"🇳🇴"{"Norway"};"🇵🇱"{"Poland"};"🇵🇹"{"Portugal"};"🇷🇴"{"Romania"};"🇷🇸"{"Serbia"};"🇸🇪"{"Sweden"};"🇸🇮"{"Slovenia"};"🇸🇰"{"Slovakia"}
        }
    }
}

function Group-Unstable {
    param($list)
    $objs = foreach($line in $list){
        $country = Get-CountryName-Unstable $line
        if(-not $country){ $country = "Unknown" }
        [PSCustomObject]@{Country=$country;Line=$line}
    }

    $groups = $objs | Group-Object Country | Sort-Object Name
    $out = New-Object System.Collections.Generic.List[string]
    $counter = 1

    foreach($g in $groups){
        $out.Add("")
        $out.Add("### $($g.Name)")
        $out.Add("")
        foreach($item in ($g.Group | Sort-Object Line)){
            if($item.Line -match '#(\d{4})\|'){
                $newNum="{0:D4}" -f $counter
                $item.Line=$item.Line -replace '#\d{4}\|', "#$newNum|"
            }
            $out.Add($item.Line)
            $counter++
        }
    }
    return $out
}

$finalUnstPartial = Group-Unstable $finalUnstPartial
$finalUnstDead    = Group-Unstable $finalUnstDead

