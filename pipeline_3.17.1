# 01. INIT
Write-Host "[INIT] Pipeline v3.17.1 heavy-mode starting..." -ForegroundColor Cyan

# 02. TRUST-TAIL FLAG DETECTOR
function Extract-ExistingFlag {
    param([string]$line)
    if ($line -match '#.*?(🇦🇺|🇦🇹|🇧🇪|🇧🇬|🇧🇷|🇨🇦|🇨🇭|🇨🇿|🇩🇪|🇩🇰|🇪🇸|🇪🇪|🇪🇺|🇫🇮|🇫🇷|🇬🇧|🇬🇷|🇭🇷|🇭🇺|🇮🇪|🇮🇸|🇮🇹|🇱🇻|🇱🇹|🇱🇺|🇳🇱|🇳🇴|🇵🇱|🇵🇹|🇷🇴|🇷🇺|🇷🇸|🇸🇪|🇸🇮|🇸🇰|🇺🇸)') { return $Matches[1] }
    $map = @{
        "russia"="🇷🇺";"ru"="🇷🇺";"germany"="🇩🇪";"de"="🇩🇪";"france"="🇫🇷";"fr"="🇫🇷";
        "netherlands"="🇳🇱";"nl"="🇳🇱";"sweden"="🇸🇪";"se"="🇸🇪";"finland"="🇫🇮";"fi"="🇫🇮";
        "latvia"="🇱🇻";"lv"="🇱🇻";"lithuania"="🇱🇹";"lt"="🇱🇹";"estonia"="🇪🇪";"ee"="🇪🇪";
        "norway"="🇳🇴";"no"="🇳🇴";"poland"="🇵🇱";"pl"="🇵🇱";"spain"="🇪🇸";"es"="🇪🇸";
        "italy"="🇮🇹";"it"="🇮🇹";"portugal"="🇵🇹";"pt"="🇵🇹"
    }
    foreach ($k in $map.Keys) { if ($line -match "#.*?$k") { return $map[$k] } }
    return $null
}
function Get-FinalFlag { param([string]$rawLine) $existing = Extract-ExistingFlag $rawLine; if ($existing) { return $existing }; return "" }

# 03. TRANSPORT LETTER
function Get-TransportLetter {
    param($o)
    if ($o.Security -eq 'reality') {
        if ($o.Type -eq 'grpc') { return 'G' }
        if ($o.IsVision) { return 'V' }
        return 'R'
    }
    return 'X'
}

# 04. SAFE NAME REWRITE
function Rewrite-Name {
    param($raw,$suffix)
    if ($raw -match '#') { return ($raw -replace '#.*$', "#$suffix") }
    return "$raw#$suffix"
}

# 05. LOGGER
$LOG_LEVEL="INFO";$LOG_TO_FILE=$true;$LOG_FILE="$PSScriptRoot\pipeline.log"
function Write-Log {
    param([string]$Level,[string]$Message)
    $levels=@{"DEBUG"=1;"INFO"=2;"WARN"=3;"ERROR"=4;"NONE"=99}
    if ($levels[$Level] -lt $levels[$LOG_LEVEL]) { return }
    $ts=(Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
    $line="[{0}] [{1}] {2}" -f $ts,$Level,$Message
    switch ($Level) {"DEBUG"{$c="DarkGray"}"INFO"{$c="White"}"WARN"{$c="Yellow"}"ERROR"{$c="Red"}default{$c="White"}}
    Write-Host $line -ForegroundColor $c
    if ($LOG_TO_FILE) { Add-Content -Path $LOG_FILE -Value $line }
}
function Log-Debug { param($m) Write-Log "DEBUG" $m }
function Log-Info  { param($m) Write-Log "INFO"  $m }
function Log-Warn  { param($m) Write-Log "WARN"  $m }
function Log-Error { param($m) Write-Log "ERROR" $m }
function Log-Validator { param([string]$Message) Write-Log "WARN" "[VALIDATOR] $Message" }

# 06. PARSER
function Parse-Query {
    param($query)
    $result=@{}
    if (-not $query) { return $result }
    foreach ($pair in $query -split '&') {
        if ($pair -match '=') {
            $k,$v=$pair -split '=',2
            try { $v=[System.Net.WebUtility]::UrlDecode($v) } catch {}
            $result[$k]=$v
        }
    }
    return $result
}
function Is-ValidHostName { param($h) if (-not $h) {return $false}; if ($h -notmatch '^[a-zA-Z0-9\.\-

\[\]

:]+$') {return $false}; return $true }
function Parse-HostPort {
    param($hp)
    if (-not $hp) { return $null }
    if ($hp -match '^

\[(.+)\]

:(.+)$') { $h=$Matches[1];$p=$Matches[2] }
    else { $h,$p=$hp -split ':',2 }
    if (-not $h -or -not $p) { return $null }
    if ($p -notmatch '^\d{1,5}$') { return $null }
    $pn=[int]$p
    if ($pn -lt 1 -or $pn -gt 65535) { return $null }
    if (-not (Is-ValidHostName $h)) { return $null }
    return [PSCustomObject]@{HostName=$h;Port=$pn}
}
function Parse-VlessLine {
    param($line)
    if ($line -notmatch '^vless://') { return $null }
    $raw=$line.Trim();$line=$line.Trim()
    $parts=$line -replace '^vless://','' -split '@'
    if ($parts.Count -ne 2) { return $null }
    $id=$parts[0];$rest=$parts[1]
    $hp,$qp=$rest -split '\?',2
    $hpObj=Parse-HostPort $hp
    if (-not $hpObj) { return $null }
    $q=Parse-Query $qp
    return [PSCustomObject]@{
        Raw=$raw;Id=$id;HostName=$hpObj.HostName;Port=$hpObj.Port;Query=$q;
        Security=$q["security"];Type=$q["type"];Flow=$q["flow"];Mode=$q["mode"];
        SNI=$q["sni"];FP=$q["fp"];PBK=$q["pbk"];IsVision=($q["flow"] -eq "xtls-rprx-vision")
    }
}

# 06.5 VALIDATOR
function Test-VlessRealityNode {
    param($Node)
    if ($Node.Raw -notmatch '^vless://') { Log-Validator "Unsupported scheme"; return $false }
    if (-not $Node.Id) { Log-Validator "Missing UUID"; return $false }
    if (-not $Node.HostName -or -not $Node.Port) { Log-Validator "Missing host or port"; return $false }
    $q=$Node.Query
    if ($q.security -eq 'reality') {
        if (-not $q.pbk) { Log-Validator "Missing pbk for Reality"; return $false }
        if (-not $q.sni) { Log-Validator "Missing sni for Reality"; return $false }
    }
    return $true
}

# 07. LOAD + PARSE + VALIDATE + DEDUP + TARGETS
Write-Host "[LOAD] Reading input.txt..."
$inputLines=Get-Content "input.txt" -Encoding UTF8 | Where-Object { $_.Trim() -ne "" }
Write-Host "[LOAD] $($inputLines.Count) lines loaded."

$parsed=foreach ($line in $inputLines) {
    $o=Parse-VlessLine $line
    if (-not $o) { continue }
    if (-not (Test-VlessRealityNode $o)) { continue }
    $o
}
Write-Host "[PARSE] Parsed: $($parsed.Count)"

$parsed=$parsed | ForEach-Object {
    $_ | Add-Member -NotePropertyName DedupKey -NotePropertyValue (
        '{0}|{1}|{2}|{3}|{4}|{5}|{6}|{7}' -f `
        $_.Id,$_.HostName,$_.Port,$_.PBK,$_.SNI,$_.Flow,$_.Type,$_.Security
    ) -Force
    $_
}

$dedup=$parsed | Group-Object DedupKey | ForEach-Object { $_.Group[0] }
Write-Host "[DEDUP] Unique: $($dedup.Count)"

$filtered=$dedup | Where-Object { $_.Security -eq 'reality' }
Write-Host "[FILTER] Reality: $($filtered.Count)"

$targets=$filtered | Sort-Object HostName,Port
Write-Host "[TARGETS] Count: $($targets.Count)"

# 07.5 LIGHT-UNSTABLE DETECTOR
$targets = $targets | ForEach-Object {
    $mark = ""
    if ($_.RawLine -match "type=grpc" -and $_.RawLine -match "packetEncoding=none") { $mark = "!" }
    elseif ($_.RawLine -match "\?&") { $mark = "!" }
    elseif ($_.RawLine -match "%252F") { $mark = "!" }
    elseif ($_.RawLine -match "type=xhttp") { $mark = "!" }

    $_ | Add-Member -NotePropertyName UnstableMark -NotePropertyValue $mark -Force
    $_
}
Write-Host "[LIGHT] Marked: $($targets.Count)"


# 08. HEAVY-MODE CHECK
Write-Host "[CHECK] Starting heavy-mode v3.17.1 (50 threads, extended TLS + ALPN strict + HEAD)..."
Add-Type -AssemblyName System.Collections
$pool=[runspacefactory]::CreateRunspacePool(1,50);$pool.Open()
$jobs=New-Object System.Collections.ArrayList
$total=$targets.Count;$global:done=0;$global:aliveCount=0;$global:deadCount=0;$startTime=Get-Date

foreach ($o in $targets) {
    $ps=[powershell]::Create();$ps.RunspacePool=$pool
    $null=$ps.AddScript({
        param($HostName,$Port,$SNI)
        function Test-TCP { param($h,$p,$t) try{$c=New-Object System.Net.Sockets.TcpClient;$iar=$c.BeginConnect($h,$p,$null,$null);if(-not $iar.AsyncWaitHandle.WaitOne($t)){$c.Close();return $false};$c.EndConnect($iar);$c.Close();return $true}catch{}return $false }
        function Test-HEAD { param($h,$p,$s,$t) try{$c=New-Object System.Net.Sockets.TcpClient;$iar=$c.BeginConnect($h,$p,$null,$null);if(-not $iar.AsyncWaitHandle.WaitOne($t)){$c.Close();return $false};$c.EndConnect($iar);$s2=$c.GetStream();$w=New-Object System.IO.StreamWriter($s2);$w.Write("HEAD / HTTP/1.1`r`nHost: $s`r`nConnection: close`r`n`r`n");$w.Flush();$b=New-Object byte[] 128;$r=$s2.Read($b,0,128);$c.Close();if($r -gt 0){$txt=[System.Text.Encoding]::ASCII.GetString($b,0,$r);if($txt -match "HTTP"){return $true}}}catch{}return $false }
        function Test-TLS-Extended { param($h,$p,$t) $hex="";$bytes=-split ($hex -replace '..','$& '),' ' | ? {$_ -ne ""} | % {[Convert]::ToByte($_,16)};try{$c=New-Object System.Net.Sockets.TcpClient;$iar=$c.BeginConnect($h,$p,$null,$null);if(-not $iar.AsyncWaitHandle.WaitOne($t)){$c.Close();return $false};$c.EndConnect($iar);$s=$c.GetStream();$s.Write($bytes,0,$bytes.Length);$b=New-Object byte[] 2048;$r=$s.Read($b,0,2048);$c.Close();if($r -lt 5){return $false};if($b[0] -ne 22){return $false};if($b[1] -ne 3){return $false};return $true}catch{}return $false }
        function Test-ALPN { param($h,$p,$t) $hex="";$bytes=-split ($hex -replace '..','$& '),' ' | ? {$_ -ne ""} | % {[Convert]::ToByte($_,16)};try{$c=New-Object System.Net.Sockets.TcpClient;$iar=$c.BeginConnect($h,$p,$null,$null);if(-not $iar.AsyncWaitHandle.WaitOne($t)){$c.Close();return $false};$c.EndConnect($iar);$s=$c.GetStream();$s.Write($bytes,0,$bytes.Length);$b=New-Object byte[] 4096;$r=$s.Read($b,0,4096);$c.Close();if($r -lt 10){return $false};$txt=[BitConverter]::ToString($b,0,$r);if($txt -match "68-32" -or $txt -match "68-74-74-70-2F-31-2E-31"){return $true};return $false}catch{}return $false }
        $alive=$false
        if(Test-TCP $HostName $Port 56){$alive=$true};Start-Sleep -Milliseconds 80
        if(-not $alive){if(Test-TCP $HostName $Port 560){$alive=$true}};Start-Sleep -Milliseconds 80
        if(-not $alive){if(Test-HEAD $HostName $Port $SNI 560){$alive=$true}};Start-Sleep -Milliseconds 80
        if(-not $alive){if(Test-TLS-Extended $HostName $Port 560){$alive=$true}};Start-Sleep -Milliseconds 80
        if(-not $alive){if(Test-ALPN $HostName $Port 560){$alive=$true}};Start-Sleep -Milliseconds 80
        if(-not $alive){if(Test-TCP $HostName $Port 560){$alive=$true}}
        return [PSCustomObject]@{HostName=$HostName;Port=$Port;Alive=$alive}
    }).AddArgument($o.HostName).AddArgument($o.Port).AddArgument($o.SNI)
    $handle=$ps.BeginInvoke()
    $jobs.Add([PSCustomObject]@{PS=$ps;Handle=$handle;Obj=$o}) | Out-Null
}

Write-Host "[CHECK] Waiting for results..."
$alive=New-Object System.Collections.Generic.List[object]
$dead=New-Object System.Collections.Generic.List[object]

# 09. CLASSIFICATION
$global:aliveCount=0;$global:deadCount=0;$global:unstableCount=0;$global:done=0
$digits=$total.ToString().Length

foreach ($j in $jobs) {
    $result=$j.PS.EndInvoke($j.Handle);$j.PS.Dispose()
    $heavyAlive=$result.Alive

    function Quick-TCP { param($h,$p)
        try{
            $c=New-Object System.Net.Sockets.TcpClient
            $iar=$c.BeginConnect($h,$p,$null,$null)
            if(-not $iar.AsyncWaitHandle.WaitOne(1500)){
                $c.Close();return $false
            }
            $c.EndConnect($iar);$c.Close();return $true
        }catch{return $false}
    }

    $tcpFast=Quick-TCP $j.Obj.HostName $j.Obj.Port

    if($heavyAlive){
        $alive.Add($j.Obj)
        $global:aliveCount++
    }
    elseif($j.Obj.UnstableMark -eq "!"){
        $j.Obj | Add-Member -NotePropertyName "UnstableMark" -NotePropertyValue "!" -Force
        $dead.Add($j.Obj)
        $global:unstableCount++
    }
    elseif($tcpFast){
        $j.Obj | Add-Member -NotePropertyName "UnstableMark" -NotePropertyValue "~" -Force
        $dead.Add($j.Obj)
        $global:unstableCount++
    }
    else{
        $j.Obj | Add-Member -NotePropertyName "UnstableMark" -NotePropertyValue "-" -Force
        $dead.Add($j.Obj)
        $global:deadCount++
    }

    $global:done++
    $percent=[math]::Round(($global:done/$total)*100)
    $cur=$global:done.ToString().PadLeft($digits,'0')
    $tot=$total.ToString().PadLeft($digits,'0')
    $aliveStr=$global:aliveCount.ToString().PadLeft($digits,'0')
    $deadStr=$global:deadCount.ToString().PadLeft($digits,'0')
    $unstableStr=$global:unstableCount.ToString().PadLeft($digits,'0')
    $elapsed=(Get-Date)-$startTime
    $sec=[math]::Max($elapsed.TotalSeconds,0.1)
    $speed="{0:N1}" -f ($global:done/$sec)
    $eta="{0:N1}s" -f (($total-$global:done)/($global:done/$sec))

    Write-Host ("`r[PROGRESS] {0,3}% | {1}/{2} | ALIVE: {3} | DEAD: {4} | UNSTABLE: {5} | {6} cfg/s | ETA ~{7}" -f `
        $percent,$cur,$tot,$aliveStr,$deadStr,$unstableStr,$speed,$eta) -NoNewline
}

Write-Host ""
$pool.Close()
Write-Host "[CHECK] Alive: $($alive.Count), Dead: $($dead.Count), Unstable: $($global:unstableCount)" -ForegroundColor Cyan

# 10. SORT BY TRANSPORT
function Sort-ByTransport {
    param($list)
    return $list | Sort-Object @{
        Expression = {
            switch (Get-TransportLetter $_) {
                'G' {1}
                'V' {2}
                'R' {3}
                default {9}
            }
        }
    }, HostName, Port
}

$aliveSorted=Sort-ByTransport $alive
$deadSorted=Sort-ByTransport $dead

# 11. ANYCAST DETECTOR
function Is-Anycast {
    param($o)
    $flag=Get-FinalFlag $o.Raw
    if($flag){return $false}
    $h=$o.HostName.ToLower()
    if($h -match '\.(ru|de|nl|se|fi|fr|pl|es|it|pt|lv|lt|ee|no)$'){return $false}
    $ranges=@('^5\.101\.','^5\.188\.','^45\.155\.','^45\.67\.','^185\.162\.','^185\.213\.','^172\.67\.','^104\.21\.','^188\.114\.')
    foreach($r in $ranges){if($h -match $r){return $true}}
    $same=$targets | Where-Object { $_.PBK -eq $o.PBK -and $_.SNI -eq $o.SNI -and $_.HostName -ne $o.HostName }
    if($same.Count -ge 2){return $true}
    return $false
}

# 12. RU/EU/ANYCAST SPLIT
function Is-Russian {
    param($o)
    $h=$o.HostName.ToLower()
    if($h -match '\.ru$'){return $true}
    if($o.Raw -match '#(.+)$'){
        $tag=$Matches[1].ToLower()
        if($tag -match 'ru|rus|russia'){return $true}
    }
    return $false
}

# 13. OUTPUT LISTS
$finalEU=New-Object System.Collections.Generic.List[string]
$finalRU=New-Object System.Collections.Generic.List[string]
$finalANYCAST=New-Object System.Collections.Generic.List[string]
$finalUnstPartial=New-Object System.Collections.Generic.List[string]
$finalUnstDead=New-Object System.Collections.Generic.List[string]

# 14. BUILD ALIVE LISTS
Write-Host "[FINAL] Building alive lists..."
$counterEU=1;$counterRU=1;$counterANY=1
$EUFlags=@("🇦🇹","🇧🇪","🇨🇿","🇩🇪","🇩🇰","🇪🇸","🇪🇪","🇫🇮","🇫🇷","🇬🇷","🇭🇷","🇭🇺","🇮🇪","🇮🇸","🇮🇹","🇱🇻","🇱🇹","🇱🇺","🇳🇱","🇳🇴","🇵🇱","🇵🇹","🇷🇴","🇷🇸","🇸🇪","🇸🇮","🇸🇰")

foreach($o in $aliveSorted){
    $t=Get-TransportLetter $o
    $flag=Get-FinalFlag $o.Raw
    if(Is-Anycast $o -or -not $flag -or $flag -eq "" -or ($EUFlags -notcontains $flag)){
        $num="{0:D4}" -f $counterANY
        $suffix="$num|$t|🌀|"
        $finalANYCAST.Add((Rewrite-Name $o.Raw $suffix))
        $counterANY++
        continue
    }
    if(Is-Russian $o){
        $num="{0:D4}" -f $counterRU
        $suffix="$num|$t|🇷🇺|"
        $finalRU.Add((Rewrite-Name $o.Raw $suffix))
        $counterRU++
        continue
    }
    $num="{0:D4}" -f $counterEU
    $suffix="$num|$t|$flag|"
    $finalEU.Add((Rewrite-Name $o.Raw $suffix))
    $counterEU++
}

# 15. BUILD UNSTABLE LISTS
Write-Host "[FINAL] Building unstable lists..."
$counterPartial=1;$counterDead=1

foreach($o in $deadSorted){
    $t=Get-TransportLetter $o
    $flag=Get-FinalFlag $o.Raw

    if($o.UnstableMark -eq "!" -or $o.UnstableMark -eq "~"){
        $num="{0:D4}" -f $counterPartial
        $suffix="$num|$t|$flag|~"
        $finalUnstPartial.Add((Rewrite-Name $o.Raw $suffix))
        $counterPartial++
    }
    else{
        $num="{0:D4}" -f $counterDead
        $suffix="$num|$t|$flag|-"
        $finalUnstDead.Add((Rewrite-Name $o.Raw $suffix))
        $counterDead++
    }
}

