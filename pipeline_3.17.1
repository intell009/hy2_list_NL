}

# 17. DEBUG EU OBJECTS
Write-Host "[DEBUG] HARD SCAN of euObjects..." -ForegroundColor Yellow
$idx=0
foreach($obj in $euObjects){
    if($obj -eq $null){Write-Host ("[#{0:D4}] NULL OBJECT" -f $idx) -ForegroundColor Red;$idx++;continue}
    if($obj.GetType().Name -ne 'PSCustomObject'){Write-Host ("[#{0:D4}] WRONG TYPE: {1}" -f $idx,$obj.GetType().Name) -ForegroundColor Red;$idx++;continue}
    if(-not ($obj.PSObject.Properties.Name -contains 'Country')){Write-Host ("[#{0:D4}] NO Country PROPERTY" -f $idx) -ForegroundColor Red;$idx++;continue}
    if($obj.Country -and $obj.Country.GetType().Name -ne 'String'){Write-Host ("[#{0:D4}] Country NOT STRING" -f $idx) -ForegroundColor Red;$idx++;continue}
    if(-not $obj.Country -or $obj.Country.Trim().Length -eq 0){Write-Host ("[#{0:D4}] Country EMPTY" -f $idx) -ForegroundColor Red;$idx++;continue}
    if($obj.Country -match '\r|\n'){Write-Host ("[#{0:D4}] Country HAS NEWLINES" -f $idx) -ForegroundColor Red;$idx++;continue}
    if(-not ($obj.PSObject.Properties.Name -contains 'Line')){Write-Host ("[#{0:D4}] NO Line PROPERTY" -f $idx) -ForegroundColor Red;$idx++;continue}
    $idx++
}
Write-Host "[DEBUG] HARD SCAN COMPLETE." -ForegroundColor Yellow

# 18. WRITE OUTPUT FILES
Write-Host "[WRITE] Writing output files..."
$euOutput | Set-Content "alive_eu.txt" -Encoding UTF8
$finalRU | Set-Content "alive_ru.txt" -Encoding UTF8
$finalANYCAST | Set-Content "alive_anycast.txt" -Encoding UTF8
$finalUnstPartial | Set-Content "0_unstable_partial.txt" -Encoding UTF8
$finalUnstDead | Set-Content "0_unstable_dead.txt" -Encoding UTF8

Write-Host "[DONE] Pipeline v3.17.1 finished." -ForegroundColor Cyan
